{
  "name": "fais-ton-plein",
  "description": "FaisTonPlein is a modern web application that helps you locate gas stations and compare fuel prices in real time. With a smooth interactive map and instant search, find the cheapest option near you in the blink of an eye. (Only available in France)",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"NEXT,GREP\" -c \"cyan.dim,magenta.dim\" \"next dev --turbo -p 3000\" \"grepai watch\"",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "react-doctor": "npx -y react-doctor@latest . --verbose",
    "fetch-names": "node scripts/fetch-station-names.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@duckdb/duckdb-wasm": "1.33.1-dev20.0",
    "apache-arrow": "^21.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "maplibre-gl": "^5.19.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-map-gl": "^8.1.0",
    "shadcn": "^4.0.2",
    "sonner": "^2.0.7",
    "supercluster": "^8.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "use-supercluster": "^1.2.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-tailwindcss": "4.0.0-beta.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}